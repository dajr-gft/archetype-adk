# ADK backend selection. This archetype targets Vertex AI (global endpoint).
# The `global` endpoint is required by the `gemini-*-latest` model selectors.
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global

# Alternative: Google AI Studio (API key) instead of Vertex AI.
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GOOGLE_API_KEY=your-api-key

# ── Observability (recommended for auditable domains) ─────────────────────────
# ADK emits OpenTelemetry traces/logs/metrics. For an auditable decision, the
# trace IS the decision provenance. On Vertex AI Agent Runtime enable tracing at
# deploy time; on Cloud Run/GKE export OTel to Cloud Trace. To control whether
# prompt/response *content* is captured in logs (PII), set:
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=NO_CONTENT   # metadata only
